# ─────────────────────────────────────────────────────────────
# GitHub Secrets Reference
# ─────────────────────────────────────────────────────────────
# These environment variables / GitHub Secrets are required
# for the CI/CD workflow (.github/workflows/deploy-vertex-ai.yml).
# Copy this file to .env and fill in your values (DO NOT COMMIT .env).
# ─────────────────────────────────────────────────────────────

# ── GCP Authentication (Workload Identity Federation) ────────
WIF_PROVIDER=projects/<PROJECT_NUM>/locations/global/workloadIdentityPools/<POOL>/providers/<PROVIDER>
DEPLOYER_SA=deployer@<PROJECT>.iam.gserviceaccount.com

# ── GCP Core ─────────────────────────────────────────────────
GCP_PROJECT=<YOUR_GCP_PROJECT_ID>
GCP_REGION=us-central1
ARTIFACT_BUCKET=gs://<YOUR_STAGING_BUCKET>
SERVICE_ACCOUNT=<YOUR_SA>@<PROJECT>.iam.gserviceaccount.com
KMS_KEY=                           # Optional: projects/<P>/locations/<L>/keyRings/<KR>/cryptoKeys/<K>

# ── Pipeline Parameters (passed as --param to submit_pipeline_job.py) ─
PARAM_BQ_PROJECT=<YOUR_GCP_PROJECT_ID>
PARAM_GCS_PROJECT=<YOUR_GCP_PROJECT_ID>
PARAM_BQ_TABLE=<YOUR_DATASET>.model_eval_result
PARAM_EXPORT_BUCKET=<YOUR_BUCKET_NAME>
FETCH_RAW_DATA_QUERY=SELECT * FROM `<PROJECT>.<DATASET>.train_data` WHERE date <= CURRENT_DATE()
